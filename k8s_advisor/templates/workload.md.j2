- Memory: Avg={{ analysis.avg_mem | int }}Mi, P50={{ analysis.mem_p50 | int }}Mi, P95={{ analysis.mem_p95 | int }}Mi, Max={{ analysis.mem_max | int }}Mi
{% if analysis.cpu_throttle_pct > 0 -%}
- CPU Throttling: {{ "%.1f" | format(analysis.cpu_throttle_pct) }}%
{% endif -%}
{% if analysis.mem_volatility_cv > 0 -%}
- Memory Volatility: {{ "%.1f" | format(analysis.mem_volatility_cv) }}% CV
{% endif %}

